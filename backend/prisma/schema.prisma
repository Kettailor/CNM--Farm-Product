generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum ActivityType {
  FERTILIZER
  PESTICIDE
  IRRIGATION
  SOIL_PREPARATION
  PLANTING
  OTHER
}

enum BatchStatus {
  HARVESTED
  IN_PROCESSING
  PACKAGED
  IN_TRANSIT
  IN_WAREHOUSE
  DELIVERED
  REJECTED
}

enum ProcessingType {
  WASHING
  SORTING
  DRYING
  CUTTING
  MIXING
  PACKING
  OTHER
}

enum ShipmentStatus {
  PLANNED
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

enum WarehouseLogType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  SUSPENDED
}

enum InspectionResult {
  PASS
  FAIL
  CONDITIONAL
}

enum QrCodeStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum LifecycleStage {
  FARM
  HARVEST
  PROCESSING
  LOGISTICS
  WAREHOUSE
  RETAIL
  CONSUMER_SCAN
}

enum ActorType {
  FARM
  PROCESSOR
  LOGISTICS
  WAREHOUSE
  RETAILER
  CONSUMER
  INSPECTOR
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  username     String     @unique
  fullName     String
  passwordHash String
  status       UserStatus @default(ACTIVE)

  userRoles  UserRole[]
  farmsOwned Farm[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  description String?

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Farm {
  id           String   @id @default(uuid()) @db.Uuid
  ownerUserId  String   @map("owner_user_id") @db.Uuid
  code         String   @unique
  name         String
  locationText String   @map("location_text")
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  areaHectares Decimal  @map("area_hectares") @db.Decimal(12, 2)

  owner             User               @relation(fields: [ownerUserId], references: [id])
  farmPlots         FarmPlot[]
  crops             Crop[]
  activities        FarmingActivity[]
  harvestRecords    HarvestRecord[]
  productLifecycles ProductLifecycle[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  Batch     Batch[]

  @@index([ownerUserId])
  @@index([name])
  @@map("farms")
}

model FarmPlot {
  id           String  @id @default(uuid()) @db.Uuid
  farmId       String  @map("farm_id") @db.Uuid
  code         String
  name         String
  areaHectares Decimal @map("area_hectares") @db.Decimal(12, 2)
  soilType     String? @map("soil_type")

  farm           Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crops          Crop[]
  activities     FarmingActivity[]
  irrigationLogs IrrigationLog[]
  harvestRecords HarvestRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([farmId, code])
  @@index([farmId])
  @@map("farm_plots")
}

model Crop {
  id                  String    @id @default(uuid()) @db.Uuid
  farmId              String    @map("farm_id") @db.Uuid
  farmPlotId          String?   @map("farm_plot_id") @db.Uuid
  code                String
  cropName            String    @map("crop_name")
  variety             String?
  plantingDate        DateTime  @map("planting_date")
  expectedHarvestDate DateTime? @map("expected_harvest_date")
  status              String

  farm           Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmPlot       FarmPlot?       @relation(fields: [farmPlotId], references: [id], onDelete: SetNull)
  harvestRecords HarvestRecord[]
  batchItems     BatchItem[]

  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  FarmingActivity FarmingActivity[]

  @@unique([farmId, code])
  @@index([farmPlotId])
  @@index([cropName])
  @@map("crops")
}

model Fertilizer {
  id                  String  @id @default(uuid()) @db.Uuid
  code                String  @unique
  name                String
  manufacturer        String?
  nutrientComposition String? @map("nutrient_composition")

  activities FarmingActivity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fertilizers")
}

model Pesticide {
  id               String  @id @default(uuid()) @db.Uuid
  code             String  @unique
  name             String
  manufacturer     String?
  activeIngredient String? @map("active_ingredient")

  activities FarmingActivity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pesticides")
}

model FarmingActivity {
  id           String       @id @default(uuid()) @db.Uuid
  farmId       String       @map("farm_id") @db.Uuid
  farmPlotId   String?      @map("farm_plot_id") @db.Uuid
  cropId       String?      @map("crop_id") @db.Uuid
  activityType ActivityType @map("activity_type")
  activityDate DateTime     @map("activity_date")
  description  String?
  fertilizerId String?      @map("fertilizer_id") @db.Uuid
  pesticideId  String?      @map("pesticide_id") @db.Uuid
  quantityUsed Decimal?     @map("quantity_used") @db.Decimal(12, 3)
  quantityUnit String?      @map("quantity_unit")

  farm       Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmPlot   FarmPlot?   @relation(fields: [farmPlotId], references: [id], onDelete: SetNull)
  crop       Crop?       @relation(fields: [cropId], references: [id], onDelete: SetNull)
  fertilizer Fertilizer? @relation(fields: [fertilizerId], references: [id], onDelete: SetNull)
  pesticide  Pesticide?  @relation(fields: [pesticideId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([farmId, activityDate])
  @@index([farmPlotId])
  @@index([cropId])
  @@index([activityType])
  @@map("farming_activities")
}

model IrrigationLog {
  id              String   @id @default(uuid()) @db.Uuid
  farmPlotId      String   @map("farm_plot_id") @db.Uuid
  irrigationDate  DateTime @map("irrigation_date")
  waterSource     String?  @map("water_source")
  volumeLiters    Decimal? @map("volume_liters") @db.Decimal(14, 3)
  method          String?
  durationMinutes Int?     @map("duration_minutes")

  farmPlot FarmPlot @relation(fields: [farmPlotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([farmPlotId, irrigationDate])
  @@map("irrigation_logs")
}

model HarvestRecord {
  id           String   @id @default(uuid()) @db.Uuid
  farmId       String   @map("farm_id") @db.Uuid
  farmPlotId   String?  @map("farm_plot_id") @db.Uuid
  cropId       String?  @map("crop_id") @db.Uuid
  harvestDate  DateTime @map("harvest_date")
  quantityKg   Decimal  @map("quantity_kg") @db.Decimal(14, 3)
  qualityGrade String?  @map("quality_grade")
  notes        String?

  farm       Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmPlot   FarmPlot?   @relation(fields: [farmPlotId], references: [id], onDelete: SetNull)
  crop       Crop?       @relation(fields: [cropId], references: [id], onDelete: SetNull)
  batchItems BatchItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([farmId, harvestDate])
  @@index([cropId])
  @@map("harvest_records")
}

model Batch {
  id                  String      @id @default(uuid()) @db.Uuid
  farmId              String      @map("farm_id") @db.Uuid
  batchCode           String      @unique @map("batch_code")
  status              BatchStatus
  harvestDate         DateTime    @map("harvest_date")
  totalQuantityKg     Decimal     @map("total_quantity_kg") @db.Decimal(14, 3)
  currentOwnerActorId String?     @map("current_owner_actor_id") @db.Uuid
  notes               String?

  farm              Farm               @relation(fields: [farmId], references: [id], onDelete: Restrict)
  currentOwnerActor SupplyChainActor?  @relation("BatchCurrentOwner", fields: [currentOwnerActorId], references: [id], onDelete: SetNull)
  batchItems        BatchItem[]
  batchHistory      BatchHistory[]
  processingRecords ProcessingRecord[]
  packaging         Packaging[]
  shipments         Shipment[]
  qrCodes           QrCode[]
  certifications    Certification[]
  traceabilityLogs  TraceabilityLog[]
  productLifecycles ProductLifecycle[]

  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  WarehouseLog     WarehouseLog[]
  InspectionReport InspectionReport[]

  @@index([farmId, harvestDate])
  @@index([status])
  @@index([currentOwnerActorId])
  @@map("batches")
}

model BatchItem {
  id              String  @id @default(uuid()) @db.Uuid
  batchId         String  @map("batch_id") @db.Uuid
  cropId          String? @map("crop_id") @db.Uuid
  harvestRecordId String? @map("harvest_record_id") @db.Uuid
  quantityKg      Decimal @map("quantity_kg") @db.Decimal(14, 3)

  batch         Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  crop          Crop?          @relation(fields: [cropId], references: [id], onDelete: SetNull)
  harvestRecord HarvestRecord? @relation(fields: [harvestRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId])
  @@index([cropId])
  @@index([harvestRecordId])
  @@map("batch_items")
}

model BatchHistory {
  id         String      @id @default(uuid()) @db.Uuid
  batchId    String      @map("batch_id") @db.Uuid
  fromStatus BatchStatus @map("from_status")
  toStatus   BatchStatus @map("to_status")
  changedAt  DateTime    @map("changed_at")
  changedBy  String?     @map("changed_by")
  remarks    String?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId, changedAt])
  @@map("batch_history")
}

model ProcessingRecord {
  id               String         @id @default(uuid()) @db.Uuid
  batchId          String         @map("batch_id") @db.Uuid
  processingType   ProcessingType @map("processing_type")
  facilityActorId  String?        @map("facility_actor_id") @db.Uuid
  processDate      DateTime       @map("process_date")
  inputQuantityKg  Decimal?       @map("input_quantity_kg") @db.Decimal(14, 3)
  outputQuantityKg Decimal?       @map("output_quantity_kg") @db.Decimal(14, 3)
  notes            String?

  batch             Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facilityActor     SupplyChainActor?  @relation("ProcessingFacility", fields: [facilityActorId], references: [id], onDelete: SetNull)
  processedProducts ProcessedProduct[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId, processDate])
  @@index([facilityActorId])
  @@map("processing_records")
}

model ProcessedProduct {
  id                 String  @id @default(uuid()) @db.Uuid
  processingRecordId String  @map("processing_record_id") @db.Uuid
  productName        String  @map("product_name")
  sku                String
  quantity           Decimal @db.Decimal(14, 3)
  unit               String

  processingRecord ProcessingRecord @relation(fields: [processingRecordId], references: [id], onDelete: Cascade)
  packaging        Packaging[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([processingRecordId])
  @@index([sku])
  @@map("processed_products")
}

model Packaging {
  id                 String   @id @default(uuid()) @db.Uuid
  batchId            String   @map("batch_id") @db.Uuid
  processedProductId String?  @map("processed_product_id") @db.Uuid
  packageType        String   @map("package_type")
  packageDate        DateTime @map("package_date")
  unitCount          Int      @map("unit_count")
  netWeightKg        Decimal? @map("net_weight_kg") @db.Decimal(14, 3)
  lotNumber          String?  @map("lot_number")

  batch            Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  processedProduct ProcessedProduct? @relation(fields: [processedProductId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId, packageDate])
  @@index([processedProductId])
  @@map("packaging")
}

model SupplyChainActor {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  actorType    ActorType @map("actor_type")
  name         String
  contactName  String?   @map("contact_name")
  contactPhone String?   @map("contact_phone")
  address      String?

  warehouses        Warehouse[]
  outgoingShipments Shipment[]         @relation("ShipmentSource")
  incomingShipments Shipment[]         @relation("ShipmentDestination")
  currentBatches    Batch[]            @relation("BatchCurrentOwner")
  processings       ProcessingRecord[] @relation("ProcessingFacility")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([actorType])
  @@map("supply_chain_actors")
}

model Warehouse {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String   @map("actor_id") @db.Uuid
  code         String
  name         String
  locationText String   @map("location_text")
  capacityKg   Decimal? @map("capacity_kg") @db.Decimal(14, 3)

  actor         SupplyChainActor @relation(fields: [actorId], references: [id], onDelete: Cascade)
  warehouseLogs WarehouseLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([actorId, code])
  @@index([actorId])
  @@map("warehouses")
}

model WarehouseLog {
  id          String           @id @default(uuid()) @db.Uuid
  warehouseId String           @map("warehouse_id") @db.Uuid
  batchId     String           @map("batch_id") @db.Uuid
  logType     WarehouseLogType @map("log_type")
  quantityKg  Decimal          @map("quantity_kg") @db.Decimal(14, 3)
  loggedAt    DateTime         @map("logged_at")
  referenceNo String?          @map("reference_no")
  notes       String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batch     Batch     @relation(fields: [batchId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([warehouseId, loggedAt])
  @@index([batchId, loggedAt])
  @@map("warehouse_logs")
}

model Shipment {
  id                 String         @id @default(uuid()) @db.Uuid
  batchId            String         @map("batch_id") @db.Uuid
  shipmentCode       String         @unique @map("shipment_code")
  sourceActorId      String         @map("source_actor_id") @db.Uuid
  destinationActorId String         @map("destination_actor_id") @db.Uuid
  carrierName        String         @map("carrier_name")
  vehicleNo          String?        @map("vehicle_no")
  departedAt         DateTime?      @map("departed_at")
  estimatedArrivalAt DateTime?      @map("estimated_arrival_at")
  deliveredAt        DateTime?      @map("delivered_at")
  status             ShipmentStatus @default(PLANNED)

  batch            Batch              @relation(fields: [batchId], references: [id], onDelete: Restrict)
  sourceActor      SupplyChainActor   @relation("ShipmentSource", fields: [sourceActorId], references: [id], onDelete: Restrict)
  destinationActor SupplyChainActor   @relation("ShipmentDestination", fields: [destinationActorId], references: [id], onDelete: Restrict)
  trackingLogs     ShipmentTracking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId])
  @@index([sourceActorId])
  @@index([destinationActorId])
  @@index([status])
  @@map("shipments")
}

model ShipmentTracking {
  id            String   @id @default(uuid()) @db.Uuid
  shipmentId    String   @map("shipment_id") @db.Uuid
  eventTime     DateTime @map("event_time")
  locationText  String   @map("location_text")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  statusMessage String   @map("status_message")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shipmentId, eventTime])
  @@map("shipment_tracking")
}

model QrCode {
  id          String       @id @default(uuid()) @db.Uuid
  batchId     String       @map("batch_id") @db.Uuid
  qrToken     String       @unique @map("qr_token")
  qrPayload   Json         @map("qr_payload")
  qrImageUrl  String?      @map("qr_image_url")
  status      QrCodeStatus @default(ACTIVE)
  generatedAt DateTime     @map("generated_at")
  expiresAt   DateTime?    @map("expires_at")

  batch    Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scanLogs QrScanLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId])
  @@index([status])
  @@map("qr_codes")
}

model QrScanLog {
  id            String   @id @default(uuid()) @db.Uuid
  qrCodeId      String   @map("qr_code_id") @db.Uuid
  scannedAt     DateTime @map("scanned_at")
  scannerType   String?  @map("scanner_type")
  scannerUserId String?  @map("scanner_user_id") @db.Uuid
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  geoLocation   String?  @map("geo_location")

  qrCode QrCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([qrCodeId, scannedAt])
  @@index([scannerUserId])
  @@map("qr_scan_logs")
}

model Certification {
  id               String              @id @default(uuid()) @db.Uuid
  batchId          String              @map("batch_id") @db.Uuid
  certType         String              @map("cert_type")
  certCode         String              @unique @map("cert_code")
  issuingAuthority String              @map("issuing_authority")
  issueDate        DateTime            @map("issue_date")
  expiryDate       DateTime?           @map("expiry_date")
  status           CertificationStatus @default(PENDING)

  batch             Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  inspectionReports InspectionReport[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId])
  @@index([status])
  @@map("certifications")
}

model InspectionReport {
  id               String           @id @default(uuid()) @db.Uuid
  certificationId  String?          @map("certification_id") @db.Uuid
  batchId          String           @map("batch_id") @db.Uuid
  inspectorName    String           @map("inspector_name")
  inspectorOrg     String?          @map("inspector_org")
  inspectionDate   DateTime         @map("inspection_date")
  result           InspectionResult
  findings         String?
  correctiveAction String?          @map("corrective_action")

  certification Certification? @relation(fields: [certificationId], references: [id], onDelete: SetNull)
  batch         Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId, inspectionDate])
  @@index([certificationId])
  @@map("inspection_reports")
}

model TraceabilityLog {
  id             String         @id @default(uuid()) @db.Uuid
  batchId        String         @map("batch_id") @db.Uuid
  stage          LifecycleStage
  eventTime      DateTime       @map("event_time")
  actorId        String?        @map("actor_id") @db.Uuid
  sourceTable    String?        @map("source_table")
  sourceRecordId String?        @map("source_record_id") @db.Uuid
  description    String?
  metadata       Json?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([batchId, eventTime])
  @@index([stage, eventTime])
  @@index([actorId])
  @@map("traceability_logs")
}

model ProductLifecycle {
  id               String         @id @default(uuid()) @db.Uuid
  batchId          String         @map("batch_id") @db.Uuid
  farmId           String         @map("farm_id") @db.Uuid
  currentStage     LifecycleStage @map("current_stage")
  latestTraceLogId String?        @map("latest_trace_log_id") @db.Uuid
  lastUpdatedAt    DateTime       @map("last_updated_at")
  consumerVisible  Boolean        @default(true) @map("consumer_visible")

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  farm  Farm  @relation(fields: [farmId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([batchId])
  @@index([farmId])
  @@index([currentStage])
  @@map("product_lifecycle")
}
