generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  ARCHITECT
  SUPERVISOR
  WORKER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  COMPLETED
}

enum Phase {
  PLANNING
  SITE_WORKS
  BUILDING_CONSTRUCTION
  INSTALLATION
  INSPECTION_COMPLETION
}

enum ResourceType {
  LABOR
  EQUIPMENT
  MATERIAL
  VEHICLE
  TOOL
  OTHER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  managedProjects Project[]            @relation("ProjectManager")
  taskAssignments TaskAssignment[]
  activityLogs    ActivityLog[]
}

model Project {
  id          String        @id @default(uuid())
  name        String
  location    String
  description String?
  startDate   DateTime      @map("start_date")
  endDate     DateTime      @map("end_date")
  status      ProjectStatus @default(PLANNING)
  managerId   String?       @map("manager_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  manager      User?            @relation("ProjectManager", fields: [managerId], references: [id])
  tasks        Task[]
  resources    Resource[]
  milestones   Milestone[]
  activityLogs ActivityLog[]

  @@index([managerId])
}

model Task {
  id          String     @id @default(uuid())
  projectId   String     @map("project_id")
  name        String
  phase       Phase
  description String?
  startDate   DateTime   @map("start_date")
  endDate     DateTime   @map("end_date")
  status      TaskStatus @default(TODO)
  progress    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userAssignments TaskAssignment[]
  resources       TaskResource[]
  dependencies    TaskDependency[] @relation("TaskDependsOn")
  dependedBy      TaskDependency[] @relation("TaskDependedBy")
  progressLogs    ProgressLog[]

  @@index([projectId, phase])
  @@index([status])
}

model TaskAssignment {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model Resource {
  id           String       @id @default(uuid())
  projectId    String?      @map("project_id")
  name         String
  type         ResourceType
  cost         Decimal      @db.Decimal(12, 2)
  availability Int          @default(100)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskLinks    TaskResource[]

  @@index([projectId])
}

model TaskResource {
  id         String   @id @default(uuid())
  taskId      String   @map("task_id")
  resourceId  String   @map("resource_id")
  quantity    Int      @default(1)
  assignedAt  DateTime @default(now()) @map("assigned_at")

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([taskId, resourceId])
}

model TaskDependency {
  id            String @id @default(uuid())
  taskId        String @map("task_id")
  dependsOnTaskId String @map("depends_on_task_id")

  task          Task @relation("TaskDependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependedBy", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
}

model ProgressLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  progress    Int
  comment     String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Milestone {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  title       String
  dueDate     DateTime @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, dueDate])
}

model ActivityLog {
  id        String   @id @default(uuid())
  projectId String?  @map("project_id")
  userId    String?  @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}
