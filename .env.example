DATABASE_URL=postgresql://farmhub:farmhub@localhost:55432/farmhub
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KetKat-EcoFarm

# Use a long random value in production.
AUTH_SECRET=change-me-use-a-long-random-secret
NEXTAUTH_SECRET=change-me-use-a-long-random-secret

# Used by protected maintenance/refresh endpoints.
CRON_SECRET=change-me-cron-secret

# SMTP settings for user invitation emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=no-reply@example.com
SMTP_PASS=change-me
MAIL_FROM=KetKat-EcoFarm <no-reply@example.com>

# Optional contact details shown in invitation email footer.
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+84 000 000 000
