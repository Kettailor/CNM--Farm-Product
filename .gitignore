# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================
# KetKat-EcoFarm .gitignore
# =========================

# Dependencies
/node_modules/
/.pnp
.pnp.js

# Package managers
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnpm-store/

# Build outputs
/.next/
/out/
/build/
/dist/

# Coverage / test artifacts
/coverage/
*.lcov

# Caches
.npm/
.eslintcache
.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment files
.env
.env.*
!.env.example

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Security / certs
*.pem

# Temporary files
*.tmp
*.temp

# Local folders not for versioning
UI-UX-Template_WebKetKat/